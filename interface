from flask import Flask, render_template
import pandas as pd
import json

app = Flask(__name__)

# -----------------------------
# Load + clean data
# -----------------------------
def load_data():
    df = pd.read_parquet("data/parquet/chunk_0.parquet")

    def normalize(conv):
        try:
            if hasattr(conv, "to_pylist"):
                conv = conv.to_pylist()

            if isinstance(conv, str):
                conv = json.loads(conv)

            cleaned = []
            if isinstance(conv, list):
                for msg in conv:
                    if hasattr(msg, "as_py"):
                        msg = msg.as_py()

                    if isinstance(msg, dict):
                        role = str(msg.get("role", "unknown"))
                        content = str(msg.get("content", ""))

                        cleaned.append({
                            "role": role,
                            "content": content
                        })

            return cleaned
        except:
            return []

    df["conversation"] = df["conversation"].apply(normalize)

    return df


df = load_data()

# -----------------------------
# Routes
# -----------------------------
@app.route("/")
def index():
    conversations = df.head(10).to_dict(orient="records")
    return render_template("index.html", conversations=conversations)


if __name__ == "__main__":
    app.run(debug=True)